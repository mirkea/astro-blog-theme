---
import Layout from "./Layout.astro";
import Tag from "../components/Tag.astro";
import PostMeta from "../components/PostMeta.astro";
import ShareButtons from "../components/ShareButtons.astro";

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  readingTime?: string;
  tags?: string[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  readingTime = "5 min read",
  tags = [],
} = Astro.props;

let canonicalURL;
try {
  canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://example.com");
} catch {
  canonicalURL = new URL("https://example.com");
}

let heroImageUrl: string | null = null;
if (heroImage) {
  try {
    if (heroImage.startsWith("http")) {
      heroImageUrl = heroImage;
    } else if (heroImage.startsWith("/")) {
      heroImageUrl = Astro.site ? new URL(heroImage, Astro.site).toString() : heroImage;
    } else {
      heroImageUrl = heroImage;
    }
  } catch {
    heroImageUrl = heroImage;
  }
}
---

<Layout title={title} description={description}>
  <article class="mx-auto max-w-4xl">
    <div class="mb-8">
      <h1
        class="mb-4 text-4xl font-bold tracking-tight text-zinc-900 sm:text-5xl dark:text-zinc-100"
      >
        {title}
      </h1>

      <PostMeta pubDate={pubDate} readingTime={readingTime} variant="compact" />

      {
        tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <Tag tag={tag} size="sm" />
            ))}
          </div>
        )
      }
    </div>

    {
      heroImage && (
        <div class="relative mb-8 overflow-hidden rounded-md shadow-lg">
          <div class="aspect-video w-full">
            <img
              src={heroImageUrl}
              alt={title}
              class="h-full w-full object-cover"
              loading="eager"
              width="896"
              height="504"
            />
          </div>
          <div class="absolute inset-0 bg-linear-to-t from-black/30 to-transparent" />
        </div>
      )
    }

    <div class="markdown-content">
      <slot />
    </div>

    <div class="mt-12 border-t border-zinc-200 pt-8 dark:border-zinc-800">
      <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
        <ShareButtons url={canonicalURL.toString()} title={title} />
      </div>
    </div>

    {
      updatedDate && (
        <div class="mt-8 text-sm text-zinc-500 italic dark:text-zinc-400">
          Last updated on <PostMeta pubDate={updatedDate} variant="compact" />
        </div>
      )
    }
  </article>

  <slot name="after-article" />

  <div class="mx-auto mt-16 border-t border-zinc-200 pt-10 dark:border-zinc-800">
    <h2 class="mb-6 text-lg font-semibold text-zinc-900 dark:text-zinc-100">Comments</h2>
    <div
      id="cusdis_thread"
      data-host="https://cusdis.com"
      data-app-id="e48f5d58-50c3-46ff-a952-7547a70bf8ca"
      data-page-id={Astro.url.pathname}
      data-page-url={canonicalURL.toString()}
      data-page-title={title}
      data-theme="light"
      style="min-height: 300px"
    >
    </div>
    <script is:inline>
      (function () {
        var thread = document.getElementById("cusdis_thread");
        if (thread) {
          var isDark = document.documentElement.classList.contains("dark");
          thread.setAttribute("data-theme", isDark ? "dark" : "light");
        }
      })();
    </script>
    <script is:inline async defer src="https://cusdis.com/js/cusdis.es.js"></script>
    <script>
      function syncCusdisTheme() {
        const isDark = document.documentElement.classList.contains("dark");
        const theme = isDark ? "dark" : "light";
        const thread = document.getElementById("cusdis_thread");
        if (!thread) return;
        thread.setAttribute("data-theme", theme);
        if ((window as any).CUSDIS) {
          try {
            (window as any).CUSDIS.setTheme(theme);
          } catch {
            // iframe contentWindow not yet ready; theme will be applied on load
          }
        }
      }

      function initCusdisThemeSync() {
        syncCusdisTheme();
        new MutationObserver(syncCusdisTheme).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }

      document.addEventListener("DOMContentLoaded", initCusdisThemeSync);
      document.addEventListener("astro:page-load", initCusdisThemeSync);

      function watchCusdisHeight() {
        const thread = document.getElementById("cusdis_thread");
        if (!thread) return;

        const injectCusdisStyles = (doc: Document) => {
          if (doc.getElementById("cusdis-custom-styles")) return;
          const style = doc.createElement("style");
          style.id = "cusdis-custom-styles";
          style.textContent = `
            @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');
            html { color-scheme: light !important; font-family: "Inter", ui-sans-serif, system-ui, sans-serif; font-size: 14px; line-height: 1.5; }
            html, body { background: transparent !important; margin: 0; padding: 0; }
            * { box-sizing: border-box; font-family: inherit; }
            label { font-size: 0.875rem; font-weight: 500; color: #3f3f46; display: block; margin-bottom: 0.375rem; }
            .dark label { color: #a1a1aa; }
            input, textarea { width: 100%; border-radius: 0.375rem; border: 1px solid #e4e4e7; padding: 0.5rem 0.75rem; font-size: 0.875rem; background: #fff; color: #18181b; outline: none; transition: border-color 0.15s ease, box-shadow 0.15s ease; }
            input:focus, textarea:focus { border-color: #a1a1aa; box-shadow: 0 0 0 3px rgba(161,161,170,0.2); }
            .dark input, .dark textarea { background: #27272a; color: #f4f4f5; border-color: #3f3f46; }
            .dark input:focus, .dark textarea:focus { border-color: #71717a; box-shadow: 0 0 0 3px rgba(113,113,122,0.2); }
            button { display: inline-flex; align-items: center; justify-content: center; border-radius: 0.5rem; border: none; padding: 0.5rem 1.25rem; font-size: 0.875rem; font-weight: 500; height: auto !important; cursor: pointer; transition: background 0.15s ease, color 0.15s ease; background: #18181b !important; color: #f4f4f5 !important; }
            button:hover { background: #3f3f46 !important; }
            .dark button { background: #f4f4f5 !important; color: #18181b !important; }
            .dark button:hover { background: #d4d4d8 !important; }
            .comment-header strong, [class*="username"], [class*="author"] { font-weight: 600; font-size: 0.875rem; color: #18181b; }
            .dark [class*="username"], .dark [class*="author"] { color: #f4f4f5; }
            [class*="date"], [class*="time"], time { font-size: 0.75rem; color: #71717a; }
            p { font-size: 0.875rem; color: #3f3f46; line-height: 1.6; margin: 0.25rem 0; }
            .dark p { color: #a1a1aa; }
            a { color: #71717a; font-size: 0.75rem; text-decoration: none; }
            a:hover { color: #3f3f46; }
            .dark a { color: #71717a; }
            .dark a:hover { color: #a1a1aa; }
          `;
          doc.head.appendChild(style);
        };

        const attach = (iframe: HTMLIFrameElement) => {
          iframe.setAttribute("allowtransparency", "true");
          iframe.setAttribute("title", "Comments");
          iframe.style.background = "transparent";
          const tryObserve = () => {
            try {
              const body = (iframe.contentDocument as Document)?.body;
              if (!body) {
                setTimeout(tryObserve, 100);
                return;
              }
              injectCusdisStyles(iframe.contentDocument as Document);
              new ResizeObserver(() => {
                const h = (iframe.contentDocument as Document).body.scrollHeight;
                if (h > 0) iframe.style.height = h + "px";
              }).observe(body);
            } catch {
              setTimeout(tryObserve, 200);
            }
          };
          iframe.addEventListener("load", tryObserve);
          tryObserve();
        };

        const mo = new MutationObserver((mutations) => {
          for (const m of mutations) {
            for (const node of m.addedNodes) {
              if ((node as Element).tagName === "IFRAME") {
                attach(node as HTMLIFrameElement);
                mo.disconnect();
              }
            }
          }
        });
        mo.observe(thread, { childList: true });
        const existing = thread.querySelector("iframe") as HTMLIFrameElement | null;
        if (existing) {
          attach(existing);
          mo.disconnect();
        }
      }

      document.addEventListener("DOMContentLoaded", watchCusdisHeight);
      document.addEventListener("astro:page-load", watchCusdisHeight);
    </script>
  </div>
</Layout>

<script>
  function setupBlogPost() {
    const article = document.querySelector("article");
    if (article) {
      article.classList.add("article-entering");
      setTimeout(() => article.classList.remove("article-entering"), 1000);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("heading-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: "0px 0px -100px 0px" },
    );

    document.querySelectorAll("article h2, article h3").forEach((h) => {
      h.classList.add("heading-animated");
      observer.observe(h);
    });

    enhanceCodeBlocks();
    enhanceBlockquotes();
  }

  function enhanceCodeBlocks() {
    document.querySelectorAll("pre code").forEach((codeBlock) => {
      const pre = codeBlock.parentElement!;
      if (pre.classList.contains("enhanced")) return;
      pre.classList.add("enhanced");

      const copyButton = document.createElement("button");
      copyButton.className = "copy-code-button";
      copyButton.setAttribute("aria-label", "Copy code");
      copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" /></svg>`;

      copyButton.addEventListener("click", () => {
        navigator.clipboard.writeText(codeBlock.textContent ?? "");
        copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>`;
        setTimeout(() => {
          copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" /></svg>`;
        }, 2000);
      });

      pre.appendChild(copyButton);

      const lines = (codeBlock.textContent ?? "").split("\n");
      const lineNumbers = document.createElement("div");
      lineNumbers.className = "line-numbers";
      lines.forEach((_, i) => {
        const span = document.createElement("span");
        span.textContent = String(i + 1);
        lineNumbers.appendChild(span);
      });
      pre.classList.add("with-line-numbers");
      pre.insertBefore(lineNumbers, codeBlock);

      const langMatch = codeBlock.className.match(/language-(\w+)/);
      if (langMatch?.[1]) {
        const lang = langMatch[1];
        const label = document.createElement("div");
        label.className = "language-label";
        label.textContent = lang;
        pre.appendChild(label);
        const badge = document.createElement("div");
        badge.className = "language-badge";
        badge.textContent = `\`\`\`${lang}`;
        pre.appendChild(badge);
      }
    });
  }

  function enhanceBlockquotes() {
    document.querySelectorAll(".markdown-content blockquote").forEach((bq) => {
      if (bq.classList.contains("enhanced-quote")) return;
      bq.classList.add("enhanced-quote");
      const icon = document.createElement("div");
      icon.className = "quote-icon";
      icon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>`;
      bq.insertBefore(icon, bq.firstChild);
    });
  }

  document.addEventListener("DOMContentLoaded", setupBlogPost);
  document.addEventListener("astro:page-load", setupBlogPost);
</script>

<style>
  #cusdis_thread iframe {
    background: transparent !important;
  }

  article img:first-of-type {
    border-radius: 1rem;
    box-shadow:
      0 10px 25px -5px rgba(0, 0, 0, 0.1),
      0 8px 10px -6px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease;
  }

  article img:first-of-type:hover {
    transform: scale(1.01);
  }

  .article-entering {
    animation: article-fade-in 0.8s ease-out forwards;
  }

  @keyframes article-fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
