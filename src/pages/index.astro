---
export const prerender = true;
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";
import Button from "../components/Button.astro";
import TagCard from "../components/TagCard.astro";

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection("blog");

const recentPosts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))].slice(0, 5);
---

<Layout title="Mirkea | PM by trade. Builder by choice.">
  <section class="theme-transition-all px-4 py-10 sm:px-6 sm:py-16 md:py-20">
    <div class="relative mx-auto max-w-2xl">
      <div class="relative text-center sm:text-left">
        <h1
          class="theme-transition-color hero-text text-3xl font-extrabold tracking-tight text-zinc-900 sm:text-4xl md:text-5xl lg:text-6xl dark:text-zinc-100"
        >
          <span class="block">PM by trade.</span>
          <span class="relative mt-1 block">
            <span class="relative inline-block">
              Builder by choice.
              <span
                class="theme-transition-bg absolute -bottom-1 left-0 h-1 w-full origin-left transform bg-zinc-800 dark:bg-zinc-200"
              ></span>
            </span>
          </span>
        </h1>
        <p
          class="theme-transition-color mx-auto mt-4 max-w-lg text-base leading-relaxed text-zinc-600 sm:mx-0 sm:mt-6 sm:text-lg md:mt-8 dark:text-zinc-400"
        >
          10 years in product, 20 in tech. Now I'm starting over - building a B2C product from idea
          to launch, in public. Everything I learn ends up here.
        </p>
        <div
          class="mt-6 flex flex-wrap justify-center gap-3 sm:mt-8 sm:justify-start sm:gap-4 md:mt-10"
        >
          <Button href={`${base}about`} variant="ghost" icon="arrow-right">More about me</Button>
        </div>
      </div>
    </div>
  </section>

  <section
    class="theme-transition-all border-t border-zinc-100 px-4 py-10 sm:px-6 sm:py-12 md:py-16 dark:border-zinc-800"
  >
    <div class="mx-auto max-w-3xl">
      <div
        class="mb-6 flex flex-col justify-between gap-4 sm:mb-8 sm:flex-row sm:items-center md:mb-12"
      >
        <h2
          class="theme-transition-color text-center text-xl font-bold tracking-tight text-zinc-900 sm:text-left sm:text-2xl md:text-3xl dark:text-zinc-100"
        >
          Recent Posts
        </h2>
        <Button href={`${base}blog`} variant="ghost" icon="arrow-right" class="self-center sm:self-auto">
          View all posts
        </Button>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8 md:gap-12 lg:grid-cols-3">
        {
          recentPosts.map((post, index) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.slug}
              readingTime={
                post.data.readingTime || `${Math.ceil(post.body.length / 2000)} min read`
              }
              tags={post.data.tags}
              heroImage={post.data.heroImage}
              index={index}
            />
          ))
        }
      </div>
    </div>
  </section>

  {
    allTags.length > 0 && (
      <section class="theme-transition-all border-t border-zinc-100 px-4 py-10 sm:px-6 sm:py-12 md:py-16 dark:border-zinc-800">
        <div class="mx-auto max-w-3xl">
          <h2 class="theme-transition-color mb-6 text-center text-xl font-bold tracking-tight text-zinc-900 sm:mb-8 sm:text-left sm:text-2xl md:text-3xl dark:text-zinc-100">
            Explore Topics
          </h2>

          <div class="mx-auto grid max-w-xs grid-cols-1 gap-3 sm:max-w-none sm:grid-cols-2 sm:gap-4 md:grid-cols-3">
            {allTags.map((tag) => {
              const tagCount = allPosts.filter(
                (post) => post.data.tags && post.data.tags.includes(tag),
              ).length;
              return <TagCard tag={tag} count={tagCount} />;
            })}
          </div>

          <div class="mt-6 text-center sm:mt-8">
            <Button href={`${base}tags`} variant="ghost" icon="arrow-right">
              View all topics
            </Button>
          </div>
        </div>
      </section>
    )
  }
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const isTouchDevice = "ontouchstart" in window || navigator.maxTouchPoints > 0;
    if (isTouchDevice) {
      document.querySelectorAll(".hover-3d").forEach((card) => {
        card.addEventListener("touchstart", () => card.classList.add("is-touched"));
        card.addEventListener("touchend", () =>
          setTimeout(() => card.classList.remove("is-touched"), 300),
        );
      });
      document.documentElement.classList.add("touch-device");
    }
  });
</script>

<style>
  @keyframes reveal-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-text span:nth-child(1) { animation: reveal-up 0.6s ease both 0.05s; }
  .hero-text span:nth-child(2) { animation: reveal-up 0.6s ease both 0.2s; }
  .hero-text + p { animation: reveal-up 0.6s ease both 0.35s; }
  .hero-text ~ div { animation: reveal-up 0.6s ease both 0.5s; }

  article.group:nth-child(1) { animation: reveal-up 0.6s ease both 0.5s; }
  article.group:nth-child(2) { animation: reveal-up 0.6s ease both 0.65s; }
  article.group:nth-child(3) { animation: reveal-up 0.6s ease both 0.8s; }

  a.group.flex.flex-col:nth-child(1) { animation: reveal-up 0.6s ease both 0.8s; }
  a.group.flex.flex-col:nth-child(2) { animation: reveal-up 0.6s ease both 0.9s; }
  a.group.flex.flex-col:nth-child(3) { animation: reveal-up 0.6s ease both 1s; }
  a.group.flex.flex-col:nth-child(4) { animation: reveal-up 0.6s ease both 1.1s; }
  a.group.flex.flex-col:nth-child(5) { animation: reveal-up 0.6s ease both 1.2s; }
  a.group.flex.flex-col:nth-child(6) { animation: reveal-up 0.6s ease both 1.3s; }

  @media (prefers-reduced-motion: reduce) {
    .hero-text span,
    .hero-text + p,
    .hero-text ~ div,
    article.group,
    a.group.flex.flex-col {
      animation: none;
    }
  }
</style>
